# Copy to .env — values in docs/creds.md.
DATABASE_URL=
DIRECT_URL=
JWT_SECRET=
JWT_EXPIRES_IN=7d
API_PORT=4000
AI_ENGINE_URL=http://localhost:8000

# Security hardening (issue #19)
# Explicit CORS allowlist (comma-separated). Leave empty for the permissive dev
# default; set to your Vercel domains in production.
CORS_ORIGINS=
# Redis for the distributed rate limiter (optional; in-process fallback if unset).
REDIS_URL=
