# NoLoop AI engine — optional config.
#
# The engine is fully deterministic and the RAG layer runs offline (hashing
# embedder + in-memory store) without ANY of these set. Provide a Groq key
# (free tier, very fast) to have an LLM rewrite each rationale in plain
# language. Get a key at https://console.groq.com/keys
GROQ_API_KEY=
NOLOOP_LLM_MODEL=llama-3.3-70b-versatile
NOLOOP_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# ── RAG (policy-document retrieval for coverage) ──────────────────────────
# Coverage is RAG-backed by default; set to 0 to force the rule-based fallback.
NOLOOP_RAG_COVERAGE=1

# Embeddings: "hash" (default, no deps, offline) or "sentence-transformers"
# (local semantic model — needs `pip install -r requirements-rag.txt`).
NOLOOP_EMBEDDING_BACKEND=hash
NOLOOP_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
NOLOOP_EMBEDDING_DIM=256

# Store: "memory" (default) or "pgvector" (production, needs DATABASE_URL +
# schema.sql applied + `pip install -r requirements-rag.txt`).
NOLOOP_RAG_STORE=memory
# DATABASE_URL=postgresql://...      # required when NOLOOP_RAG_STORE=pgvector

# Retrieval tuning.
NOLOOP_RAG_TOP_K=5
NOLOOP_RAG_CANDIDATE_K=20
NOLOOP_RAG_RRF_K=60
NOLOOP_RAG_MIN_CONFIDENCE=0.12
NOLOOP_RAG_RERANK=0
NOLOOP_RAG_RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
